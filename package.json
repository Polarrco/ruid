{
  "name": "@polarrco/ruid",
  "version": "1.4.1",
  "private": false,
  "description": "The optimised primary key generator for Database, based on UUID and cluster safe.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Polarrco/ruid"
  },
  "license": "MIT",
  "main": "index.js",
  "files": [
    "dist/",
    "typings/",
    "index.d.ts",
    "index.js"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p .",
    "watch": "tsc -w --incremental -p .",
    "test": "jest --bail --runInBand",
    "test:coverage": "jest -w=7 --ci --bail --coverage",
    "test:only-unit": "jest --bail --testNamePattern=\"Unit:\"",
    "test:only-integration": "jest --bail --testNamePattern=\"Integration:\"",
    "test:only-e2e": "jest --bail --testNamePattern=\"E2E:\"",
    "format": "prettier --write \"**/*.ts\"",
    "lint": "eslint --fix \"{lib,test}/**/*.ts\" --quiet",
    "prerelease": "npm run build && npm test",
    "release": "release-it"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -c .commitlintrc.json -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix --quiet",
      "prettier --write"
    ]
  },
  "towerflow": {
    "type": "node-lib"
  },
  "devDependencies": {
    "@commitlint/cli": "^13.1.0",
    "@commitlint/config-angular": "^13.1.0",
    "@release-it/conventional-changelog": "^3.3.0",
    "@types/jest": "^27.0.1",
    "@typescript-eslint/eslint-plugin": "^4.29.3",
    "@typescript-eslint/parser": "^4.29.3",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^3.4.1",
    "husky": "^7.0.1",
    "jest": "^27.0.6",
    "lint-staged": "^11.1.2",
    "prettier": "^2.3.2",
    "release-it": "^14.11.5",
    "ts-jest": "^27.0.5",
    "ts-node": "^10.2.1",
    "typescript": "^4.3.5"
  },
  "dependencies": {
    "@types/node": "^16.7.1",
    "@types/uuid": "^8.3.1",
    "@types/validator": "^13.6.3",
    "uuid": "^8.3.2",
    "validator": "^13.6.0"
  }
}
