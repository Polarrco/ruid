{
  "name": "@polarrco/ruid",
  "version": "1.4.1",
  "private": false,
  "description": "The optimised primary key generator for Database, based on UUID and cluster safe.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Polarrco/ruid.git"
  },
  "license": "MIT",
  "type": "commonjs",
  "main": "./index.js",
  "types": "./index.d.ts",
  "files": [
    "dist/",
    "index.d.ts",
    "index.js"
  ],
  "packageManager": "npm@11.17.0",
  "scripts": {
    "build": "rm -rf dist && tsc -p .",
    "watch": "tsc --watch --preserveWatchOutput -p .",
    "test": "npm run build && node --test --experimental-test-coverage --test-coverage-include='dist/**/*.js' --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 test/*.test.cjs",
    "test:coverage": "npm test",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm test",
    "prepare": "husky",
    "prepack": "npm run build",
    "prerelease": "npm run check",
    "release": "release-it"
  },
  "towerflow": {
    "type": "node-lib"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-angular": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "prettier": "^3.9.5",
    "release-it": "^20.2.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "dependencies": {
    "uuid": "^11.1.1"
  }
}
